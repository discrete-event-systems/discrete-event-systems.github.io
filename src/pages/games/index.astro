---
import ArtifactPlayer from '../../components/ArtifactPlayer.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const games = [
  {
    id: 'voting-lab',
    title: 'Voting Algorithm Lab',
    description:
      'Change candidates, ballots, and voting rules to see how the same preferences can produce different collective decisions.',
    facts: ['Interactive', 'Multiple rules', 'Runs locally'],
    src: '/labs/voting-lab.html',
    compressed: false,
  },
  {
    id: 'soccer-tactics',
    title: '7v7 feasible tactics',
    description:
      'Inspect a feasible soccer lineup and movement plan produced by the integer-programming model, with the full field state embedded.',
    facts: ['7v7 soccer', 'IP/MIP result', 'Tactical playback'],
    src: '/artifacts/soccer-IP-MIP-feasible.html.gz',
    compressed: true,
  },
  {
    id: 'soccer-solver',
    title: 'Solver entities',
    description:
      'Step behind the tactics view to examine the entities and constraints the solver used to construct the feasible match plan.',
    facts: ['Optimization model', 'Entity view', 'Solver trace'],
    src: '/artifacts/soccer-IP-MIP-feasible-solver.html.gz',
    compressed: true,
  },
];
---

<BaseLayout
  title="Games"
  description="Explore interactive voting and soccer game labs generated by the Discrete Event Systems engines."
>
  <header class="page-intro shell">
    <p class="eyebrow">Interactive game labs</p>
    <h1>Decisions are part of the model.</h1>
    <p class="lede">
      Change a voting system or inspect a solver-built soccer plan. Each lab runs inside a
      sandboxed frame and makes no external network requests.
    </p>
  </header>

  <div class="showcase-list shell">
    {
      games.map((game, index) => (
        <section id={game.id} aria-labelledby={`${game.id}-title`}>
          <div class="showcase-copy">
            <div>
              <span class="tag">Game lab {String(index + 1).padStart(2, '0')}</span>
              <h2 id={`${game.id}-title`}>{game.title}</h2>
              <p>{game.description}</p>
            </div>
            <div class="facts" aria-label={`${game.title} properties`}>
              {game.facts.map((fact) => <span class="fact">{fact}</span>)}
            </div>
          </div>
          <ArtifactPlayer title={game.title} src={game.src} compressed={game.compressed} />
        </section>
      ))
    }
  </div>
</BaseLayout>
