---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="The requested Discrete Event Systems page was not found.">
  <section class="hero">
    <div class="shell">
      <p class="eyebrow">404 / event not scheduled</p>
      <h1>This state is unreachable.</h1>
      <p class="lede">The page is not in the event queue. Return to a known system state.</p>
      <div class="button-row">
        <a class="button primary" href="/">Return home</a>
        <a class="button" href="/simulations/">Browse simulations</a>
      </div>
    </div>
  </section>
</BaseLayout>
