---
import ArtifactPlayer from '../../components/ArtifactPlayer.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const simulations = [
  {
    id: 'elevator',
    title: 'Elevator dispatch',
    description:
      'A coordinated-pickup simulation that exposes car motion, floor demand, and the dispatch policy over event time.',
    facts: ['Future-event list', 'Animated playback', 'Dispatch policy'],
    src: '/artifacts/elevator.html.gz',
    compressed: true,
  },
  {
    id: 'track3t',
    title: 'Track3t warehouse floor',
    description:
      'A high-density factory-floor comparison of routing and material movement, rendered as a self-contained DES artifact.',
    facts: ['Warehouse flow', 'Comparative run', '31 MB → 667 KB gzip'],
    src: '/artifacts/factory-floor-track3t.html.gz',
    compressed: true,
  },
  {
    id: 'bathroom-occupancy',
    title: 'Occupancy Monte Carlo',
    description:
      'A compact occupancy model for arrivals, service duration, waits, and utilization across repeated randomized trials.',
    facts: ['Monte Carlo', 'Queueing', 'Browser controls'],
    src: '/labs/bathrooms.html',
    compressed: false,
  },
];
---

<BaseLayout
  title="Simulations"
  description="Run and inspect elevator, warehouse, and occupancy simulations generated by the Discrete Event Systems engines."
>
  <header class="page-intro shell">
    <p class="eyebrow">Simulation gallery</p>
    <h1>Watch state become history.</h1>
    <p class="lede">
      These are original, self-contained engine renders copied from the DES source repositories.
      Large artifacts stay gzip-compressed until your browser loads them.
    </p>
  </header>

  <div class="showcase-list shell">
    {
      simulations.map((simulation, index) => (
        <section id={simulation.id} aria-labelledby={`${simulation.id}-title`}>
          <div class="showcase-copy">
            <div>
              <span class="tag">Simulation {String(index + 1).padStart(2, '0')}</span>
              <h2 id={`${simulation.id}-title`}>{simulation.title}</h2>
              <p>{simulation.description}</p>
            </div>
            <div class="facts" aria-label={`${simulation.title} properties`}>
              {simulation.facts.map((fact) => <span class="fact">{fact}</span>)}
            </div>
          </div>
          <ArtifactPlayer
            title={simulation.title}
            src={simulation.src}
            compressed={simulation.compressed}
          />
        </section>
      ))
    }
  </div>
</BaseLayout>
